generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  LEAD
  QUOTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  DECLINED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

enum ServiceType {
  CONCRETE_SEALING
  PAVER_SEALING
  DRIVEWAY_SEALING
  PATIO_SEALING
  POOL_DECK_SEALING
  COMMERCIAL_SEALING
  OTHER
}

enum DepositType {
  FIXED
  PERCENTAGE
}

enum ExpenseCategory {
  MATERIALS
  FUEL
  EQUIPMENT
  LABOR
  INSURANCE
  MARKETING
  OFFICE
  OTHER
}

model Customer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName      String
  lastName       String
  email          String?
  phone          String
  address        String
  city           String
  state          String
  zip            String
  notes          String?
  referralSource String?

  jobs     Job[]
  quotes   Quote[]
  invoices Invoice[]

  @@index([lastName])
  @@index([phone])
}

model Job {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])

  title         String
  description   String?
  serviceType   ServiceType
  status        JobStatus   @default(LEAD)

  address       String?
  city          String?
  state         String?
  zip           String?

  scheduledDate DateTime?
  completedDate DateTime?

  squareFootage Float?
  notes         String?

  // Phase 2: Review & Reseal
  reviewRequestSentAt  DateTime?
  resealDueDate        DateTime?
  resealReminderSentAt DateTime?

  // Phase 3: Job Costing
  laborHours     Float?
  laborRate      Float?
  materialCost   Float?
  crewAssignment String?

  photos   JobPhoto[]
  quotes   Quote[]
  invoices Invoice[]
  expenses Expense[]

  @@index([customerId])
  @@index([status])
  @@index([scheduledDate])
}

model JobPhoto {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  jobId   String
  job     Job    @relation(fields: [jobId], references: [id], onDelete: Cascade)

  url      String
  caption  String?
  isBefore Boolean @default(true)

  @@index([jobId])
}

model Quote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quoteNumber String      @unique
  customerId  String
  customer    Customer    @relation(fields: [customerId], references: [id])
  jobId       String?
  job         Job?        @relation(fields: [jobId], references: [id])

  status     QuoteStatus @default(DRAFT)
  validUntil DateTime?

  lineItems QuoteLineItem[]

  subtotal  Float @default(0)
  taxRate   Float @default(0)
  taxAmount Float @default(0)
  total     Float @default(0)

  notes String?

  // Phase 1: Follow-up & Deposits
  followUpCount          Int          @default(0)
  lastFollowUpAt         DateTime?
  depositAmount          Float?
  depositType            DepositType?
  depositPaid            Boolean      @default(false)
  depositPaidAt          DateTime?
  squareDepositPaymentId String?

  paymentEvents PaymentEvent[]
  invoices      Invoice[]

  @@index([customerId])
  @@index([status])
}

model QuoteLineItem {
  id      String @id @default(cuid())
  quoteId String
  quote   Quote  @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  description String
  quantity    Float
  unitPrice   Float
  total       Float

  @@index([quoteId])
}

model Invoice {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoiceNumber String        @unique
  customerId    String
  customer      Customer      @relation(fields: [customerId], references: [id])
  jobId         String?
  job           Job?          @relation(fields: [jobId], references: [id])
  quoteId       String?
  quote         Quote?        @relation(fields: [quoteId], references: [id])

  status   InvoiceStatus @default(DRAFT)
  dueDate  DateTime?
  paidDate DateTime?

  lineItems InvoiceLineItem[]

  subtotal  Float @default(0)
  taxRate   Float @default(0)
  taxAmount Float @default(0)
  total     Float @default(0)

  notes String?

  // Phase 1: Square payments
  squarePaymentId String?
  squareOrderId   String?

  paymentEvents PaymentEvent[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
}

model InvoiceLineItem {
  id        String  @id @default(cuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Float
  unitPrice   Float
  total       Float

  @@index([invoiceId])
}

// Phase 1: Payment Events
model PaymentEvent {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  quoteId   String?
  quote     Quote?   @relation(fields: [quoteId], references: [id])

  squarePaymentId String?
  squareOrderId   String?
  eventType       String
  amount          Float
  currency        String @default("USD")
  status          String
  metadata        Json?

  @@index([invoiceId])
  @@index([quoteId])
  @@index([squarePaymentId])
}

// Phase 2: App Settings
model AppSettings {
  id                   String   @id @default("singleton")
  updatedAt            DateTime @updatedAt
  reviewDelayDays      Int      @default(1)
  reviewRequestEnabled Boolean  @default(true)
  googleReviewUrl      String?
  resealReminderMonths Int      @default(24)
  resealReminderEnabled Boolean @default(true)
}

enum OutreachStatus {
  PROSPECT
  CONTACTED
  IN_CONVERSATION
  PROPOSAL_SENT
  WON
  LOST
}

// Phase 4: Expenses
model Expense {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  date        DateTime
  category    ExpenseCategory
  description String
  amount      Float
  vendor      String?
  receiptUrl  String?
  jobId       String?
  job         Job?    @relation(fields: [jobId], references: [id])
  notes       String?

  @@index([date])
  @@index([category])
  @@index([jobId])
}

// Outreach Pipeline — B2B property management sales
model PropertyManager {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companyName     String
  contactName     String
  phone           String?
  email           String?
  website         String?
  propertyCount   Int?
  estimatedValue  Float?

  status          OutreachStatus @default(PROSPECT)
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  notes           String?

  @@index([status])
}
